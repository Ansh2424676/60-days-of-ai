<style>
  :root {
    --bg: #f5f6fa;
    --card-bg: #ffffff;
    --border: #e4e7ec;
    --text-main: #1a1d29;
    --text-muted: #6b7280;
    --accent: #4f46e5;
    --accent-light: #eef2ff;
    --red: #ef4444;
    --red-bg: #fee2e2;
    --orange: #f59e0b;
    --orange-bg: #fef3c7;
    --green: #10b981;
    --green-bg: #d1fae5;
    --purple: #8b5cf6;
    --purple-bg: #ede9fe;
    --shadow: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
    --shadow-hover: 0 8px 20px rgba(0,0,0,0.08);
    --radius: 14px;
  }

  * { box-sizing: border-box; }

  .bdap-wrapper {
    background: var(--bg);
    color: var(--text-main);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    padding: 24px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .bdap-header {
    margin-bottom: 28px;
  }

  .bdap-header h1 {
    font-size: 24px;
    font-weight: 700;
    margin: 0 0 6px 0;
    letter-spacing: -0.02em;
  }

  .bdap-header p {
    color: var(--text-muted);
    font-size: 14px;
    margin: 0;
  }

  .bdap-section {
    margin-bottom: 28px;
  }

  .bdap-section-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    margin-bottom: 12px;
  }

  .bdap-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 20px;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .bdap-card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-1px);
  }

  .bdap-summary-text {
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--text-main);
  }

  .bdap-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 14px;
  }

  .bdap-takeaway-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-left: 4px solid var(--accent);
    border-radius: 10px;
    padding: 14px 16px;
    box-shadow: var(--shadow);
    font-size: 13.5px;
    line-height: 1.5;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 11.5px;
    font-weight: 600;
    padding: 3px 9px;
    border-radius: 999px;
    white-space: nowrap;
  }

  .badge-high { background: var(--red-bg); color: #b91c1c; }
  .badge-medium { background: var(--orange-bg); color: #b45309; }
  .badge-low { background: var(--green-bg); color: #047857; }
  .badge-conflict { background: var(--red-bg); color: #b91c1c; }
  .badge-question { background: var(--purple-bg); color: #6d28d9; }
  .badge-completed { background: var(--green-bg); color: #047857; }
  .badge-pending { background: var(--orange-bg); color: #b45309; }

  table.bdap-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--card-bg);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
  }

  table.bdap-table th {
    text-align: left;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--text-muted);
    background: #fafafa;
    padding: 12px 14px;
    border-bottom: 1px solid var(--border);
  }

  table.bdap-table td {
    padding: 13px 14px;
    font-size: 13.5px;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }

  table.bdap-table tr:last-child td { border-bottom: none; }
  table.bdap-table tr:hover td { background: #fafbff; }

  .bdap-list-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px 16px;
    box-shadow: var(--shadow);
    margin-bottom: 10px;
    font-size: 13.5px;
    line-height: 1.55;
  }

  .bdap-list-card:last-child { margin-bottom: 0; }

  .bdap-list-card .badge { margin-bottom: 6px; }

  details.bdap-collapsible {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 14px 18px;
    margin-bottom: 12px;
  }

  details.bdap-collapsible summary {
    cursor: pointer;
    font-weight: 600;
    font-size: 14px;
    color: var(--text-main);
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  details.bdap-collapsible summary::-webkit-details-marker { display: none; }

  details.bdap-collapsible summary::after {
    content: "+";
    font-size: 18px;
    color: var(--text-muted);
    transition: transform 0.2s ease;
  }

  details.bdap-collapsible[open] summary::after {
    transform: rotate(45deg);
  }

  .bdap-collapsible-body {
    margin-top: 12px;
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--text-main);
  }

  .bdap-speaker-name {
    font-weight: 700;
    color: var(--accent);
  }

  .bdap-note {
    font-size: 12.5px;
    color: var(--text-muted);
    font-style: italic;
    margin-top: 6px;
  }

  @media (max-width: 640px) {
    .bdap-wrapper { padding: 14px; }
    table.bdap-table th, table.bdap-table td { padding: 9px 8px; font-size: 12.5px; }
    .bdap-header h1 { font-size: 20px; }
  }
</style>

